{
  "projectName": "AISocialGame",
  "devModel": "auto",
  "repairModel": "auto",
  "testModel": "gpt-5.3-codex-spark",
  "testFallbackModel": "gpt-5.4-mini",
  "setupCommands": [
    "corepack enable",
    "cd frontend && pnpm install --frozen-lockfile"
  ],
  "testCommands": [
    "cd backend && mvn test",
    "cd frontend && pnpm build",
    "cd frontend && pnpm lint"
  ],
  "optionalAcceptanceCommands": [
    "cd frontend && pnpm test:e2e",
    "cd frontend && REAL_E2E=1 pnpm test:e2e:real",
    "cd frontend && REAL_ACCEPTANCE=1 PLAYWRIGHT_BASE_URL=https://aisocialgame.localhut.com pnpm test:acceptance"
  ],
  "protectedPaths": [
    "env.local",
    "testuser.txt",
    "backend/logs/",
    "backend/target/",
    "frontend/dist/",
    "frontend/node_modules/",
    "logs/"
  ],
  "acceptanceNotes": [
    "Real acceptance depends on auth tokens, admin password, localhut routing, Chromium, and upstream services.",
    "build.sh is deployment and migration oriented; keep it out of the default test loop."
  ],
  "notes": [
    "Use pnpm for frontend commands."
  ]
}
