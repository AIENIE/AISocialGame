{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "overall_status",
    "state",
    "summary",
    "commands_run",
    "findings",
    "p0_count",
    "p1_count",
    "p2_count",
    "p3_count"
  ],
  "properties": {
    "overall_status": {
      "type": "string",
      "enum": ["passed", "failed", "needs_human", "stopped"]
    },
    "state": {
      "type": "string",
      "enum": ["PASSED", "NEEDS_REPAIR", "NEEDS_HUMAN", "STOPPED"]
    },
    "summary": {
      "type": "string"
    },
    "commands_run": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command", "status"],
        "properties": {
          "command": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["passed", "failed", "skipped"]
          },
          "duration_seconds": { "type": "number" },
          "exit_code": { "type": ["integer", "null"] },
          "notes": { "type": "string" }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "severity",
          "type",
          "title",
          "reproduction_steps",
          "expected",
          "actual",
          "failed_command",
          "related_files",
          "suspected_root_cause",
          "suggested_fix",
          "repairEligible"
        ],
        "properties": {
          "id": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["P0", "P1", "P2", "P3"]
          },
          "type": {
            "type": "string",
            "enum": [
              "product_bug",
              "test_bug",
              "env_issue",
              "flaky",
              "unclear_requirement",
              "policy_violation"
            ]
          },
          "title": { "type": "string" },
          "reproduction_steps": {
            "type": "array",
            "items": { "type": "string" }
          },
          "expected": { "type": "string" },
          "actual": { "type": "string" },
          "failed_command": { "type": "string" },
          "related_files": {
            "type": "array",
            "items": { "type": "string" }
          },
          "suspected_root_cause": { "type": "string" },
          "suggested_fix": { "type": "string" },
          "repairEligible": { "type": "boolean" }
        }
      }
    },
    "p0_count": { "type": "integer" },
    "p1_count": { "type": "integer" },
    "p2_count": { "type": "integer" },
    "p3_count": { "type": "integer" }
  }
}
